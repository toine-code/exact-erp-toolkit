# Pick one
EXACT_VARIANT=globe          # 'globe' or 'financials'
EXACT_MOCK=1                 # set to 0 for real calls

# --- Reads via direct SQL Server (ODBC) -----------------------------
# Example connection string:
# DRIVER={ODBC Driver 18 for SQL Server};SERVER=exact-srv;DATABASE=Administration001;UID=exactro;PWD=...;TrustServerCertificate=yes
EXACT_ODBC=
EXACT_ADMIN=001

# --- Writes via Exact-XML ------------------------------------------
# Choose one transport:

# 1) Drop folder (most common for Globe):
#    Globe watches a folder for incoming XML files and processes them.
EXACT_XML_DROP_FOLDER=

# 2) Webservice (Globe XML Webservice add-on or Financials):
EXACT_XML_WEBSERVICE_URL=
EXACT_XML_USERNAME=
EXACT_XML_PASSWORD=
