# Kies één variant
EXACT_VARIANT=globe          # 'globe' of 'financials'
EXACT_MOCK=1                 # zet op 0 voor echte calls

# --- Reads via directe SQL Server (ODBC) ----------------------------
# Voorbeeld connection string:
# DRIVER={ODBC Driver 18 for SQL Server};SERVER=exact-srv;DATABASE=Administration001;UID=exactro;PWD=...;TrustServerCertificate=yes
EXACT_ODBC=
EXACT_ADMIN=001

# --- Writes via Exact-XML -------------------------------------------
# Kies één transport:

# 1) Drop folder (meest gebruikt voor Globe):
#    Globe bewaakt een folder voor binnenkomende XML-bestanden en
#    verwerkt ze automatisch.
EXACT_XML_DROP_FOLDER=

# 2) Webservice (Globe XML Webservice add-on of Financials):
EXACT_XML_WEBSERVICE_URL=
EXACT_XML_USERNAME=
EXACT_XML_PASSWORD=
